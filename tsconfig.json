{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "typeRoots": [".src/types", "./node_modules/@types"],

    "strict": true,
    "isolatedModules": true,

    "verbatimModuleSyntax": false,

    "skipLibCheck": true,
    "moduleDetection": "force",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  }
}
